<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TransparentDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item> <!--        设置后面是否要有灰色背景蒙版-->
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="NotTransparentDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item> <!--        设置后面是否要有灰色背景蒙版-->
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="BlueDatePickerTheme" parent="Theme.AppCompat.Light.Dialog">

        <item name="colorAccent">@color/primary_blue</item>

        <!-- 确认按钮样式 -->
        <item name="android:buttonBarPositiveButtonStyle">@style/PositiveDatePickerButtonStyle</item>

        <!-- 取消按钮样式 -->
        <item name="android:buttonBarNegativeButtonStyle">@style/NegativeDatePickerButtonStyle</item>

    </style>

    <!-- 按钮样式 -->
    <style name="PositiveDatePickerButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/blue_btn_background</item>

    </style>

    <style name="NegativeDatePickerButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:background">@drawable/white_btn_background</item>
    </style>
</resources>